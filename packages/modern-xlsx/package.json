{
  "name": "modern-xlsx",
  "version": "0.9.0",
  "description": "High-performance XLSX read/write library powered by Rust WASM. Full styling, encryption, data validation, conditional formatting — features SheetJS charges for, free and open source.",
  "license": "MIT",
  "author": "modern-xlsx contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/ABCrimson/modern-xlsx"
  },
  "homepage": "https://github.com/ABCrimson/modern-xlsx#readme",
  "keywords": [
    "xlsx",
    "excel",
    "spreadsheet",
    "wasm",
    "rust",
    "ooxml",
    "styles",
    "formatting",
    "data-validation",
    "conditional-formatting",
    "encryption",
    "password-protected",
    "ole2",
    "pivot-tables",
    "threaded-comments",
    "slicers",
    "timelines",
    "charts",
    "cli"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./browser": "./dist/modern-xlsx.min.js",
    "./worker": "./dist/modern-xlsx.worker.js"
  },
  "unpkg": "./dist/modern-xlsx.min.js",
  "jsdelivr": "./dist/modern-xlsx.min.js",
  "files": [
    "dist/",
    "wasm/",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "modern-xlsx": "./dist/cli.mjs"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsdown && node -e \"const f=require('fs');f.copyFileSync('wasm/modern_xlsx_wasm_bg.wasm','dist/modern-xlsx.wasm');f.renameSync('dist/modern-xlsx.min.iife.js','dist/modern-xlsx.min.js');f.renameSync('dist/modern-xlsx.min.iife.js.map','dist/modern-xlsx.min.js.map')\"",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:watch": "vitest",
    "lint": "biome check src/ __tests__/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/node": "25.3.5",
    "@vitest/browser": "4.1.0-beta.6",
    "@vitest/coverage-v8": "4.1.0-beta.6",
    "playwright": "1.59.0-alpha-2026-03-06",
    "tsdown": "0.21.0",
    "typescript": "6.0.0-dev.20260306",
    "vitest": "4.1.0-beta.6",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  }
}
